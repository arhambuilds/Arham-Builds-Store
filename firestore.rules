rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'alibabasports.in@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Products
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin() && isValidId(productId);
      
      function isValidProduct(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.slug is string && data.slug.size() <= 200 &&
               data.section in ['Templates', 'Editing Assets', 'Freebies'];
      }

      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if true; // Might be public for validation
      allow write: if isAdmin() && isValidId(couponId);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can create an order (e.g. after checkout)
      allow update, delete: if isAdmin();
    }

    // Admins
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(adminId);
    }
  }
}
