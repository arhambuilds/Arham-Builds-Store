{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A digital product in the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "currentPrice": { "type": "number" },
        "originalPrice": { "type": "number" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "section": { "type": "string", "enum": ["Templates", "Freebies", "Editing Assets"] },
        "categories": { "type": "array", "items": { "type": "string" } },
        "badge": { "type": "string", "enum": ["Hot Sell", "Trending", "Latest"] },
        "features": { 
          "type": "array", 
          "items": { 
            "type": "object", 
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "demoUrl": { "type": "string" },
        "stockCount": { "type": "number" },
        "whatYouReceive": { "type": "array", "items": { "type": "string" } },
        "productAccessUrl": { "type": "string" },
        "productAccessInstructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "title", "currentPrice", "section"]
    },
    "Order": {
      "title": "Order",
      "description": "A successful customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "razorpayPaymentId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "customerPhone": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "items": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "title": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "User with admin privileges",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "editor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/admins/{adminUid}": {
      "schema": "Admin",
      "description": "Collection of authorized admin users"
    }
  }
}
